generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum RequestStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  ORDERED
  RECEIVED
  CLOSED
}

enum UserRole {
  ADMIN
  REQUESTER
  APPROVER
  BUYER
  RECEIVER
}

enum VendorType {
  MANUFACTURER
  DISTRIBUTOR
  SERVICE_PROVIDER
  CALIBRATION_LAB
  CONTRACTOR
  OEM
  OTHER
}

enum VendorQualificationStatus {
  UNREVIEWED
  APPROVED
  PREFERRED
  RESTRICTED
  INACTIVE
}

enum PurchaseOrderStatus {
  DRAFT
  ISSUED
  ACKNOWLEDGED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
  CLOSED
}

model ProcurementRequest {
  id           String          @id @default(uuid())
  title        String
  description  String?
  department   String
  priority     Priority
  status       RequestStatus   @default(SUBMITTED)
  neededByDate DateTime?
  requestedById   String?
  requestedBy     User?           @relation("RequestRequestedBy", fields: [requestedById], references: [id])
  approvedById    String?
  approvedBy      User?           @relation("RequestApprovedBy", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  rejectionReason String?
  items           RequestItem[]
  purchaseOrders  PurchaseOrder[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  passwordHash String?
  role        UserRole @default(REQUESTER)
  department  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requestsRequested ProcurementRequest[] @relation("RequestRequestedBy")
  requestsApproved  ProcurementRequest[] @relation("RequestApprovedBy")
}

model RequestItem {
  id                   String             @id @default(uuid())
  procurementRequestId String
  procurementRequest   ProcurementRequest @relation(fields: [procurementRequestId], references: [id], onDelete: Cascade)
  itemName             String
  description          String?
  quantity             Int
  unitOfMeasure        String?
  estimatedUnitCost    Float?
  partNumber           String?
  manufacturer         String?
  notes                String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model Vendor {
  id                  String                    @id @default(uuid())
  name                String                    @unique
  contactName         String?
  email               String?
  phone               String?
  address             String?
  notes               String?
  website             String?
  vendorType          VendorType                @default(OTHER)
  industries          String[]
  specialties         String[]
  isPreferred         Boolean                   @default(false)
  qualificationStatus VendorQualificationStatus @default(UNREVIEWED)
  purchaseOrders      PurchaseOrder[]
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
}

model PurchaseOrder {
  id                   String              @id @default(uuid())
  poNumber             String              @unique
  procurementRequestId String
  procurementRequest   ProcurementRequest  @relation(fields: [procurementRequestId], references: [id], onDelete: Cascade)
  vendorId             String
  vendor               Vendor              @relation(fields: [vendorId], references: [id])
  status               PurchaseOrderStatus @default(DRAFT)
  orderDate            DateTime?
  expectedDeliveryDate DateTime?
  subtotal             Float               @default(0)
  notes                String?
  items                PurchaseOrderItem[]
  receipts             Receipt[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
}

model PurchaseOrderItem {
  id              String         @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  requestItemId   String?
  itemName        String
  description     String?
  quantity        Int
  unitOfMeasure   String?
  unitCost        Float?
  lineTotal       Float?
  partNumber      String?
  manufacturer    String?
  notes           String?
  receipts        Receipt[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model Receipt {
  id                  String            @id @default(uuid())
  purchaseOrderId     String
  purchaseOrder       PurchaseOrder     @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseOrderItemId String
  purchaseOrderItem   PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id], onDelete: Cascade)
  quantityReceived    Int
  receivedDate        DateTime          @default(now())
  receivedBy          String?
  notes               String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}
