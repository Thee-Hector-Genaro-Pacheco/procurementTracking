generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ProcurementRequest {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
